# Copiá este archivo a .env y poné tus valores reales.
# .env NUNCA se sube a git (está en .gitignore).

# --- App ---
APP_NAME=Anoven
APP_ENV=development
DEBUG=true

# --- Database ---
# Dev: SQLite local
DATABASE_URL=sqlite:///./anoven.db
# Prod (ejemplo): postgresql+psycopg://user:pass@host/dbname

# --- Auth ---
# IMPORTANTE: en producción usá una clave secreta fuerte (32+ chars aleatorios).
# Podés generar una con: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=cambia-esto-por-algo-secreto-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-poné-acá-tu-key
DEFAULT_MODEL=claude-haiku-4-5-20251001
